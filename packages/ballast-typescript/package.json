{
  "name": "@everydaydevopsio/ballast",
  "version": "5.9.1",
  "description": "CLI to install AI agent rules for docs, local-dev, CI/CD, observability, publishing, linting, logging, and testing for Cursor, Claude Code, OpenCode, and Codex",
  "main": "dist/cli.js",
  "bin": {
    "ballast-typescript": "bin/ballast.js"
  },
  "files": [
    "bin",
    "dist",
    "agents",
    "skills"
  ],
  "author": "Mark C Allen <mark@markcallen.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/everydaydevopsio/ballast.git"
  },
  "homepage": "https://github.com/everydaydevopsio/ballast#readme",
  "bugs": {
    "url": "https://github.com/everydaydevopsio/ballast/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "sync:content": "node ./scripts/sync-content.mjs",
    "sync:agents": "pnpm run sync:content",
    "sync:skills": "pnpm run sync:content",
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "prepare": "husky",
    "prepack": "pnpm run sync:content && pnpm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.18.10",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "tsc-files": "^1.1.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "lint-staged": {
    "**/*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.ts": [
      "tsc-files --noEmit",
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "yaml": "^2.8.3"
  }
}

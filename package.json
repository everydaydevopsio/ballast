{
  "name": "ballast-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter @everydaydevopsio/ballast run build",
    "test": "pnpm --filter @everydaydevopsio/ballast run test",
    "test:coverage": "pnpm --filter @everydaydevopsio/ballast run test:coverage",
    "lint": "pnpm --filter @everydaydevopsio/ballast run lint",
    "lint:fix": "pnpm --filter @everydaydevopsio/ballast run lint:fix",
    "prettier": "pnpm --filter @everydaydevopsio/ballast run prettier",
    "prettier:fix": "pnpm --filter @everydaydevopsio/ballast run prettier:fix"
  }
}
